# Copy to `infra/.env` and CHANGE AT LEAST THE PASSWORD before first use.
# docker-compose.yml refuses to start if any of the required DB_* vars
# are unset, so this file is the single source of DB credentials.

# --- App ---
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

# --- Database (TimescaleDB) ---
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=vidyutdrishti
DB_USER=vidyutdrishti
# CHANGE THIS VALUE. Provided only so the prototype runs out of the box
# on an isolated synthetic-data environment; never reuse in production.
DB_PASSWORD=change-me-before-first-use

# --- Simulator ---
SIMULATOR_SEED=42
SIMULATOR_DAYS=180
SIMULATOR_DT_COUNT=2
SIMULATOR_METERS_PER_DT=30

# --- Feature flags ---
ENABLE_RECALIBRATION=true
