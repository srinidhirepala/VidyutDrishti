# Copy to `infra/.env` and adjust as needed.

# --- App ---
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

# --- Database (TimescaleDB) ---
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=vidyutdrishti
DB_USER=vidyutdrishti
DB_PASSWORD=vidyutdrishti

# --- Simulator ---
SIMULATOR_SEED=42
SIMULATOR_DAYS=180
SIMULATOR_DT_COUNT=2
SIMULATOR_METERS_PER_DT=30

# --- Feature flags ---
ENABLE_RECALIBRATION=true
